# Face Grouper Configuration

# === Application ===
INPUT_DIR=./dataset
OUTPUT_DIR=./output

# === Models ===
MODELS_DIR=./models

# === Database (PostgreSQL + pgvector) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=face-grouper
DB_USER=face-grouper
DB_PASSWORD=secret-postgres
DB_SSLMODE=require        # For local dev you may override to 'disable', but default is secure for network deployments
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_RUN_MIGRATIONS=true

# === Redis (optional cache) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret-redis
REDIS_DB=0

# === Extraction ===
EXTRACT_WORKERS=4
GPU_ENABLED=0              # 1 для GPU, 0 для CPU
GPU_DEVICE_ID=0            # ID GPU устройства (для multi-GPU систем)
FORCE_CPU=0                # 1 для принудительного использования CPU
PROVIDER_PRIORITY=auto     # Приоритет провайдера: auto, gpu, cpu, cuda, rocm, directml
GPU_DET_SESSIONS=2
GPU_REC_SESSIONS=2
EMBED_BATCH_SIZE=64
EMBED_FLUSH_MS=10
MAX_DIM=1920
DET_THRESH=0.5

# === Clustering ===
# Cosine similarity threshold for grouping faces (0.0-1.0).
# Lower = more aggressive merging (fewer persons). Recommended: 0.30-0.40 for ArcFace.
CLUSTER_THRESHOLD=0.35

# === Organizer ===
AVATAR_UPDATE_THRESHOLD=0.10

# === Web ===
WEB_PORT=8080
WEB_SERVE=false
WEB_VIEW_ONLY=false

# === Logger ===
LOG_LEVEL=info
LOG_JSON=false
