# Face Grouper Configuration

# === Application ===
INPUT_DIR=./dataset
OUTPUT_DIR=./output

# === Models ===
MODELS_DIR=./models

# === Database (PostgreSQL + pgvector) ===
DB_HOST=localhost
DB_PORT=5432
DB_NAME=face-grouper
DB_USER=face-grouper
DB_PASSWORD=secret-postgres
DB_SSLMODE=require        # For local dev you may override to 'disable', but default is secure for network deployments
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=1h
DB_MAX_CONN_IDLE_TIME=30m
DB_HEALTH_CHECK_PERIOD=1m
DB_RUN_MIGRATIONS=true

# === Redis (optional cache) ===
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=secret-redis
REDIS_DB=0

# === Extraction ===
EXTRACT_WORKERS=12
GPU_ENABLED=1              # 1 для GPU, 0 для CPU
DET_INPUT_SIZE=640
MIN_FACE_AREA_RATIO=0.0     # Отфильтровать слишком мелкие лица (доля площади кадра), например 0.0003
GPU_DEVICE_ID=0            # ID GPU устройства (для multi-GPU систем)
FORCE_CPU=0                # 1 для принудительного использования CPU
PROVIDER_PRIORITY=rocm     # Приоритет провайдера: auto, gpu, cpu, cuda, rocm, directml
GPU_DET_SESSIONS=1
GPU_REC_SESSIONS=1

# Batch processing for recognition (optimized for RTX 5070)
EMBED_BATCH_SIZE=64        # Размер батча для распознавания (64 оптимально для RTX 5070)
EMBED_FLUSH_MS=50          # Таймаут сброса батча в мс (50мс для баланса latency/throughput)

# Smart resize: автоматическое уменьшение на основе MP
ENABLE_SMART_RESIZE=true   # true: умное ресайзирование (<2MP без изменений, 2-8MP->1920px, >8MP->2560px)
MAX_DIM=1280               # Устарело: используется только если ENABLE_SMART_RESIZE=false
DET_THRESH=0.5

# === Clustering ===
# Cosine similarity threshold for grouping faces (0.0-1.0).
# Lower = more aggressive merging (fewer persons). Recommended: 0.30-0.40 for ArcFace.
CLUSTER_THRESHOLD=0.35
CLUSTER_REFINE_FACTOR=1.0   # >1.0 строже (меньше ложных склеек), <1.0 мягче
CLUSTER_ENABLE_TWO_STAGE=false
CLUSTER_PRECLUSTER_THRESHOLD=0.0      # 0 = авто (threshold + 0.08)
CLUSTER_CENTROID_MERGE_THRESHOLD=0.0  # 0 = CLUSTER_THRESHOLD
CLUSTER_MUTUAL_K=1
CLUSTER_ENABLE_AMBIGUITY_GATE=false
CLUSTER_AMBIGUITY_TOPK=12
CLUSTER_AMBIGUITY_MEAN_MIN=0.0        # 0 = авто (refine_threshold + 0.01)
CLUSTER_AMBIGUITY_MEAN_MAX=0.0        # 0 = авто (refine_threshold + 0.12)
CLUSTER_AMBIGUITY_CENTROID_MAX=0.0    # 0 = авто (refine_threshold + 0.05)

# === Organizer ===
AVATAR_UPDATE_THRESHOLD=0.10

# === Web ===
WEB_PORT=8080
WEB_SERVE=false
WEB_VIEW_ONLY=false

# === Logger ===
LOG_LEVEL=info
LOG_JSON=false
