# Face Grouper Configuration

# === Application ===
INPUT_DIR=./dataset
OUTPUT_DIR=./output

# === Models ===
MODELS_DIR=./models

# === Extraction ===
EXTRACT_WORKERS=4
GPU_ENABLED=0              # 1 для GPU, 0 для CPU
GPU_DEVICE_ID=0            # ID GPU устройства (для multi-GPU систем)
FORCE_CPU=0                # 1 для принудительного использования CPU
PROVIDER_PRIORITY=auto     # Приоритет провайдера: auto, gpu, cpu, cuda, rocm, directml
GPU_DET_SESSIONS=2
GPU_REC_SESSIONS=2
EMBED_BATCH_SIZE=64
EMBED_FLUSH_MS=10
MAX_DIM=1920
DET_THRESH=0.5

# === Clustering ===
CLUSTER_THRESHOLD=0.5

# === Organizer ===
AVATAR_UPDATE_THRESHOLD=0.10

# === Web ===
WEB_PORT=8080
WEB_SERVE=false
WEB_VIEW_ONLY=false

# === Logger ===
LOG_LEVEL=info
LOG_JSON=false
